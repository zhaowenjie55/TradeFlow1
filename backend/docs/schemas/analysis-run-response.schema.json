{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tradeflow.local/schemas/analysis-run-response.schema.json",
  "title": "AnalysisRunApiResponse",
  "type": "object",
  "required": ["success", "data"],
  "properties": {
    "success": {
      "type": "boolean",
      "const": true
    },
    "data": {
      "$ref": "#/$defs/AnalysisRunResponse"
    },
    "errorCode": {
      "type": ["string", "null"]
    },
    "message": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "AnalysisRunResponse": {
      "type": "object",
      "required": ["taskId", "status", "report", "trace"],
      "properties": {
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["PENDING", "RUNNING", "DONE", "FAILED"]
        },
        "report": {
          "$ref": "#/$defs/AnalysisReport"
        },
        "trace": {
          "$ref": "#/$defs/AnalysisTrace"
        }
      },
      "additionalProperties": false
    },
    "AnalysisReport": {
      "type": "object",
      "required": [
        "taskId",
        "summary",
        "profitEstimate",
        "riskLevel",
        "confidenceScore",
        "reportMarkdown",
        "riskExplanations"
      ],
      "properties": {
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "profitEstimate": {
          "type": "number"
        },
        "riskLevel": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH"]
        },
        "confidenceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reportMarkdown": {
          "type": "string",
          "minLength": 1
        },
        "riskExplanations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "AnalysisTrace": {
      "type": "object",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ReasoningStep"
          }
        }
      },
      "additionalProperties": false
    },
    "ReasoningStep": {
      "type": "object",
      "required": ["stepName", "inputSummary", "decision", "explanation"],
      "properties": {
        "stepName": {
          "type": "string",
          "enum": ["matching", "profit_analysis", "risk_analysis", "final_report"]
        },
        "inputSummary": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
