# 复制为 .env 后填写。不要将含真实 Key 的 .env 提交到 Git。
#
# In the default `local` profile, application-local.yml already provides
# sensible localhost defaults for SPRING_DATASOURCE_*, so you can leave them
# unset for a plain local dev run against a localhost PostgreSQL.
#
# In any non-local profile, SPRING_DATASOURCE_URL / USERNAME / PASSWORD are
# REQUIRED — the backend will fail fast at startup if they are missing.

# --- Database (required in non-local profiles) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/tradeflow
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# 可选：若本机 Postgres 无 pgvector，可用 Docker：pgvector/pgvector:pg16 映射 5433
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/tradeflow
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres
# VECTOR_ENABLED=false

# --- LLM gateway ---
LLM_API_KEY=
# TASK_DEFAULT_MODE=REAL
# LLM_GATEWAY_ENABLED=true
# LLM_ENDPOINT_BASE=http://127.0.0.1:8001/api/llm
# LLM_CHAT_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions
# LLM_MODEL=glm-5

# --- Redis ---
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DATABASE=0
# REDIS_PASSWORD=    # set if your local Redis has `requirepass` enabled

# --- Crawler service ---
# CRAWLER_SERVICE_ENABLED=true
# CRAWLER_CACHE_ENABLED=false
# CRAWLER_SEARCH_ENDPOINT=http://127.0.0.1:8001/api/search
# CRAWLER_DETAIL_ENDPOINT=http://127.0.0.1:8001/api/detail
# PHASE1_WORKFLOW_TIMEOUT_MILLIS=60000

# --- ASR ---
# ASR_ENABLED=true
# ASR_ENDPOINT=http://127.0.0.1:8001/api/asr/transcribe

# --- Domestic / Overseas marketplace gateways ---
# DOMESTIC_GATEWAY_ENABLED=true
# DOMESTIC_API_KEY=
# OVERSEAS_GATEWAY_ENABLED=false
# OVERSEAS_SEARCH_ENDPOINT=
# OVERSEAS_API_KEY=

# --- Vector embeddings (local BGE model) ---
# VECTOR_ENABLED=true
# VECTOR_MODEL_PATH=/absolute/path/to/model_quantized.onnx
# VECTOR_TOKENIZER_PATH=/absolute/path/to/tokenizer.json
# VECTOR_FIXED_KEYWORD=   # optional: only set when you intentionally want a fixed domestic seed term
