# Local crawler runtime configuration for 1688 automation.
#
# Recommended anti-bot workflow:
# 1. Launch a real Chrome instance manually with a remote debugging port.
# 2. Reuse a persistent user profile so cookies and device state survive restarts.
# 3. Let the crawler attach over CDP instead of launching a fresh browser each time.

SERPAPI_KEY=

# Prefer a real user-driven Chrome session when 1688 starts challenging the browser.
# Example manual launch:
# /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome \
#   --remote-debugging-port=9222 \
#   --user-data-dir="$HOME/.tradeflow/chrome-cdp-profile"
PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222

# Fallback persistent profile when CDP is not available.
PLAYWRIGHT_USER_DATA_DIR=

# Keep headful mode for manual verification flows.
PLAYWRIGHT_HEADLESS=false

# Leave blank to let Playwright use its default Chromium executable.
# Set to "chrome" only when system Chrome is known to be stable in the current environment.
PLAYWRIGHT_BROWSER_CHANNEL=

# How long to wait for a human to finish a slider challenge before surfacing
# WAITING_1688_VERIFICATION back to the backend/UI.
PLAYWRIGHT_MANUAL_SOLVE_TIMEOUT_MS=15000
PLAYWRIGHT_ALLOW_MANUAL_SOLVE=true

# Optional operational knobs.
PLAYWRIGHT_SLOW_MO_MS=0
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=120000
PLAYWRIGHT_DEBUG_DIR=
PLAYWRIGHT_STORAGE_STATE_PATH=
PLAYWRIGHT_SESSION_IDLE_TTL_SECONDS=900
PLAYWRIGHT_ANTI_BOT_COOLDOWN_SECONDS=25
PLAYWRIGHT_NAVIGATION_JITTER_MIN_MS=800
PLAYWRIGHT_NAVIGATION_JITTER_MAX_MS=1800
